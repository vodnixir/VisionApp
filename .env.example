# TURN relay for the online battle (WebRTC needs it to connect phones on
# different networks). Create a free account at https://www.metered.ca
# (Open Relay, 20 GB/month free), create an app and paste its credentials here
# into a local `.env.local` (gitignored). For the GitHub Pages deploy, add the
# same three values as repository secrets with the same names.
#
# VITE_TURN_URL accepts several comma-separated turn:/turns: URLs.
VITE_TURN_URL=turn:standard.relay.metered.ca:80,turn:standard.relay.metered.ca:443,turns:standard.relay.metered.ca:443?transport=tcp
VITE_TURN_USERNAME=your-metered-username
VITE_TURN_CREDENTIAL=your-metered-credential
